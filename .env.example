# ============================================================
# Lightdash セルフホスト用 環境変数テンプレート
# cp .env.example .env して値を設定してください
# ============================================================

# --- GCP プロジェクト設定 ---
# gcloud auth application-default login で認証済みであること
GCP_PROJECT_ID=your-gcp-project-id

# --- Lightdash 暗号化シークレット（32文字以上のランダム文字列）---
# 生成: openssl rand -hex 32
LIGHTDASH_SECRET=change_me_to_a_random_32_char_string

# --- PostgreSQL（Lightdash メタデータ用）---
PGHOST=db
PGPORT=5432
PGUSER=lightdash
PGPASSWORD=lightdash_pg_password
PGDATABASE=lightdash

# --- Lightdash アプリ設定 ---
PORT=8080
LIGHTDASH_LOG_LEVEL=info
